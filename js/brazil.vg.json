{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 1000,
  "height": 560,
  "padding": 5,
  "background": null,
  "autosize": "pad",
  "title": {
    "text": "Countries that has won the world cup",
    "font": "AusWC2026",
    "fontSize": 19,
    "anchor": "start",
    "offset": 12
  },
  "signals": [
    {
      "name": "selCountry",
      "value": "All",
      "bind": {
        "input": "radio",
        "name": " ",
        "options": [
          "All",
          "Brazil",
          "Italy",
          "Germany",
          "Argentina",
          "Uruguay",
          "France",
          "England",
          "Spain"
        ]
      }
    }
  ],
  "data": [
    {
      "name": "titles",
      "values": [
        {
